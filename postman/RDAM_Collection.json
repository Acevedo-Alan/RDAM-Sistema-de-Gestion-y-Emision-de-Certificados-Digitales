            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipoCertificadoId\": 1,\n  \"circunscripcionId\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/solicitudes",
              "host": ["{{base_url}}"],
              "path": ["api", "solicitudes"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-04: Sin token retorna 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "TC-05 — Token malformado",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer token.invalido.jwt" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipoCertificadoId\": 1,\n  \"circunscripcionId\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/solicitudes",
              "host": ["{{base_url}}"],
              "path": ["api", "solicitudes"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-05: Token malformado retorna 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "TC-06 — Verificar OTP con codigo incorrecto",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"TU_EMAIL@gmail.com\",\n  \"codigo\": \"000000\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/auth/verify",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// OTP: maximo 5 intentos fallidos antes de invalidarse (MAX_ATTEMPTS=5 en OtpService)",
                  "// PRECONDICION: ejecutar TC-01 primero para que haya un OTP activo en memoria",
                  "pm.test('TC-06: Codigo OTP incorrecto retorna 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.error).to.eql('Error de autenticacion');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Solicitudes — Ciudadano",
      "description": "Operaciones del ciudadano sobre solicitudes.\n\nENDPOINTS DISPONIBLES:\n- POST /api/solicitudes — crear solicitud\n- GET  /api/solicitudes/{id}/pago-datos — obtener datos de pago (solo en APROBADA)",
      "item": [
        {
          "name": "TC-07 — Crear solicitud",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_ciudadano}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipoCertificadoId\": 1,\n  \"circunscripcionId\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/solicitudes",
              "host": ["{{base_url}}"],
              "path": ["api", "solicitudes"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-07: Crear solicitud retorna 201 PENDIENTE_REVISION', function () {",
                  "    pm.response.to.have.status(201);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.id).to.be.a('number').and.above(0);",
                  "    pm.expect(json.estado).to.eql('PENDIENTE_REVISION');",
                  "    pm.expect(json.tipoCertificado).to.eql('Certificado de Libre Deuda Alimentaria');",
                  "    pm.expect(json.createdAt).to.be.a('string').and.not.empty;",
                  "    pm.expect(json.updatedAt).to.be.a('string').and.not.empty;",
                  "    pm.collectionVariables.set('solicitud_id', json.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "TC-08 — Obtener datos de pago en estado incorrecto (FSM 422)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_ciudadano}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/solicitudes/{{solicitud_id}}/pago-datos",
              "host": ["{{base_url}}"],
              "path": ["api", "solicitudes", "{{solicitud_id}}", "pago-datos"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// PRECONDICION: solicitud en PENDIENTE_REVISION (recien creada en TC-07)",
                  "pm.test('TC-08: Pago en PENDIENTE_REVISION retorna 422', function () {",
                  "    pm.response.to.have.status(422);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.error).to.eql('Estado invalido');",
                  "    pm.expect(json.message).to.include('APROBADA');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. Solicitudes — Operador Interno",
      "description": "Operaciones del operador: tomar, aprobar, rechazar, emitir.\nTC-12 crea una segunda solicitud (solicitud_id_rechazo) para el flujo de rechazo paralelo.",
