    {
      "name": "4. Pagos",
      "description": "Flujo de pago: generar datos encriptados para PlusPagos.\nLa solicitud debe estar en APROBADA para obtener datos de pago.",
      "item": [
        {
          "name": "TC-16 — Obtener datos de pago (solicitud APROBADA)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_ciudadano}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/solicitudes/{{solicitud_id}}/pago-datos",
              "host": ["{{base_url}}"],
              "path": ["api", "solicitudes", "{{solicitud_id}}", "pago-datos"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-16: Datos de pago retorna 200 con todos los campos', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.Comercio).to.be.a('string').and.not.empty;",
                  "    pm.expect(json.TransaccionComercioId).to.be.a('string').and.not.empty;",
                  "    pm.expect(json.Monto).to.be.a('string').and.not.empty;",
                  "    pm.expect(json.Informacion).to.be.a('string');",
                  "    pm.expect(json.CallbackSuccess).to.be.a('string');",
                  "    pm.expect(json.CallbackCancel).to.be.a('string');",
                  "    pm.expect(json.UrlSuccess).to.be.a('string');",
                  "    pm.expect(json.UrlError).to.be.a('string');",
                  "    pm.expect(json.urlPasarela).to.be.a('string').and.not.empty;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "TC-17 — Pagar solicitud ajena (403/404)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_ciudadano}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/solicitudes/9999/pago-datos",
              "host": ["{{base_url}}"],
              "path": ["api", "solicitudes", "9999", "pago-datos"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-17: Solicitud ajena retorna 403 o 404', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([403, 404]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
