# ============================================================
# RDAM Backend — Template de variables de entorno
# Copiar este archivo como .env y completar los valores.
# NUNCA commitear el .env con credenciales reales.
# ============================================================

# -- Base de datos --
DB_PASSWORD=

# -- Base de datos (opcionales, tienen defaults) --
# DB_URL=jdbc:postgresql://localhost:5432/rdam
# DB_USERNAME=rdam_user

# -- SMTP (Gmail) --
# Para obtener el App Password: myaccount.google.com → Seguridad → Contraseñas de aplicaciones
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# -- JWT --
# Mínimo 32 caracteres para HMAC-SHA256
# Ejemplo de generación: openssl rand -hex 32
JWT_SECRET=

# -- JWT (opcionales, tienen defaults) --
# JWT_EXPIRATION_MS=3600000             # 1 hora (default)
# JWT_REFRESH_EXPIRATION_MS=604800000   # 7 días (default)

# -- PlusPagos Mock --
PLUSPAGOS_MERCHANT_ID=RDAM-MOCK-001
PLUSPAGOS_SECRET=mock-secret-desarrollo
PLUSPAGOS_URL=http://localhost:8081/pluspagos

# -- Adjuntos (opcional) --
# ADJUNTOS_PATH=./adjuntos
